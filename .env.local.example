# Supabase (Sydney region)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenAI (ChatGPT API) — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key
# Optional: gpt-4o, gpt-4o-mini, gpt-4-turbo, etc.
OPENAI_MODEL=gpt-4o-mini

# Email (optional for v1)
RESEND_API_KEY=
RESEND_FROM_EMAIL=Silman <notifications@silman.app>

# SMS (optional for v1)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cron (Vercel) — daily reminder notifications (~6am Sydney via UTC schedule)
CRON_SECRET=generate-a-random-secret
