# =============================================================================
# Silman — copy this file to `.env.local` and fill in real values.
# Restart `npm run dev` after any change.
# Production: set the same variables in Vercel → Settings → Environment Variables
# =============================================================================
#
# Quick checklist:
#   [ ] Supabase URL + anon + service role
#   [ ] NEXT_PUBLIC_APP_URL (production domain on Vercel)
#   [ ] Stripe secret + price ID + webhook secret
#   [ ] OPENAI_API_KEY (for Silman AI)
#   [ ] CRON_SECRET (Vercel cron for reminders)
#
# See docs/DEPLOY.md, docs/STRIPE_SETUP.md, and Settings → Integrations in the app.

# ─── Required: Supabase (region: Australia Sydney / ap-southeast-2) ───────────
# https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Required: App URL (Stripe + OAuth redirects must match this host) ────────
# Local:  http://localhost:3000
# Vercel: https://your-app.vercel.app  or  https://app.yourdomain.com.au
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Required: Stripe (14-day trial, then $29.99 AUD/month) ───────────────────
# API keys: https://dashboard.stripe.com/test/apikeys
# Webhook:  https://your-domain/api/stripe/webhook (events: checkout.session.completed, customer.subscription.*, invoice.payment_failed)
# Local:    stripe listen --forward-to localhost:3000/api/stripe/webhook
STRIPE_SECRET_KEY=REPLACE_WITH_STRIPE_SECRET_KEY
STRIPE_WEBHOOK_SECRET=REPLACE_WITH_STRIPE_WEBHOOK_SECRET
STRIPE_PRICE_ID=price_xxxxxxxxxxxxxxxx
# Optional: override trial length (default 14 days in Checkout)
# STRIPE_TRIAL_DAYS=14
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=REPLACE_WITH_STRIPE_PUBLISHABLE_KEY

# ─── Required for Silman AI (dock, command bar, @AI in messages) ─────────────
OPENAI_API_KEY=REPLACE_WITH_OPENAI_API_KEY
OPENAI_MODEL=gpt-4o-mini

# ─── Required on Vercel for scheduled reminders cron ──────────────────────────
# Generate: openssl rand -hex 32
CRON_SECRET=replace-with-a-long-random-string

# ─── Optional: email notifications ───────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=Silman <notifications@yourdomain.com.au>

# ─── Optional: SMS (later) ───────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ─── Optional: local UI fixtures only (never enable in production) ─────────────
# NEXT_PUBLIC_ENABLE_MOCK_DATA=false
